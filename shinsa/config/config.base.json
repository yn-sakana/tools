{
  "app": {
    "name": "shinsa",
    "mode": "review"
  },
  "paths": {
    "onedriveLedgerRoot": "C:/ONEDRIVE/GrantLedger",
    "onedriveCaseRoot": "C:/ONEDRIVE/GrantCases",
    "mailSourceRoot": "C:/workspace/dev/tools/shinsa/data/source/mail",
    "cloneRoot": "C:/workspace/dev/tools/shinsa/data/clone",
    "indexRoot": "C:/workspace/dev/tools/shinsa/data/index",
    "workRoot": "C:/workspace/dev/tools/shinsa/data/work",
    "logRoot": "C:/workspace/dev/tools/shinsa/logs"
  },
  "outlook": {
    "enabled": true,
    "targetFolders": ["Inbox"],
    "saveMsg": true,
    "saveAttachments": true,
    "maxItemsPerFolder": 200
  },
  "ledger": {
    "casesFileName": "cases.json",
    "contactsFileName": "contacts.json",
    "keyField": "case_id",
    "editableFields": ["status", "assigned_to", "review_note", "missing_documents"]
  },
  "gui": {
    "title": "shinsa",
    "visibleColumns": ["case_id", "organization_name", "contact_email", "status", "assigned_to", "mail_count", "attachment_count"]
  },
  "review": {
    "defaultStatus": "received"
  }
}
